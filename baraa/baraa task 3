def calculate_utm_hectares(p1, p2, p3, p4):
    lon_coords = [p1[1], p2[1], p3[1], p4[1]]
    lat_coords = [p1[0], p2[0], p3[0], p4[0]]
    
    poly_wgs84 = Polygon(zip(lon_coords, lat_coords)).convex_hull
    centroid_lon = poly_wgs84.centroid.x
    centroid_lat = poly_wgs84.centroid.y
    
    utm_zone = int(math.floor((centroid_lon + 180) / 6) + 1)
    hemisphere = 'north' if centroid_lat >= 0 else 'south'
    epsg_code = f"+proj=utm +zone={utm_zone} +{hemisphere} +datum=WGS84 +units=m +no_defs"
    
    project = pyproj.Transformer.from_crs("EPSG:4326", epsg_code, always_xy=True).transform
    poly_utm = Polygon([project(x, y) for x, y in poly_wgs84.exterior.coords])
    
    area_hectares = poly_utm.area / 10000.0  # Convert square meters to Hectares
    return area_hectares, centroid_lat, centroid_lon


def fetch_live_features(lat, lon):
    # 1. Meteorological Layer (Open-Meteo)
    try:
        weather_url = f"https://archive-api.open-meteo.com/v1/archive?latitude={lat}&longitude={lon}&start_date=2025-01-01&end_date=2025-12-31&daily=temperature_2m_mean,rain_sum&timezone=auto"
        w_res = requests.get(weather_url, timeout=5).json()
        live_temp = np.mean(w_res['daily']['temperature_2m_mean'])
        live_rain = np.sum(w_res['daily']['rain_sum'])
    except Exception:
        live_temp, live_rain = 22.8, 195.4  # Default pipeline fallbacks
        
    # 2. Edaphic Layer (SoilGrids)
    try:
        soil_url = f"https://rest.soilgrids.org/soilgrids/v2.0/properties/query?lon={lon}&lat={lat}&property=phh2o&property=clay&value=mean&depth=5-15cm"
        s_res = requests.get(soil_url, timeout=5).json()
        live_ph = s_res['properties']['layers'][1]['depths'][0]['values']['mean'] / 10.0
        live_clay = s_res['properties']['layers'][0]['depths'][0]['values']['mean'] / 10.0
    except Exception:
        live_ph, live_clay = 7.6, 39.8  

    # 3. Remote Sensing Proxy Layer
    live_ndvi = 0.74  
    
    return {
        "avg_temp": live_temp,
        "average_rain_fall_mm_per_year": live_rain,
        "NDVI": live_ndvi,
        "soil_pH": live_ph,
        "clay_fraction": live_clay
    }


def estimate_wheat_yield(p1, p2, p3, p4):
    """ Main entry point function mandated by technical assignment brief """
    hectares, center_lat, center_lon = calculate_utm_hectares(p1, p2, p3, p4)
    features_dict = fetch_live_features(center_lat, center_lon)
    
    input_df = pd.DataFrame([{
        "avg_temp": features_dict["avg_temp"],
        "average_rain_fall_mm_per_year": features_dict["average_rain_fall_mm_per_year"],
        "NDVI": features_dict["NDVI"],
        "soil_pH": features_dict["soil_pH"],
        "clay_fraction": features_dict["clay_fraction"]
    }])
    
    predicted_density = production_pipeline.predict(input_df)[0]
    total_yield = predicted_density * hectares
    
    return hectares, predicted_density, total_yield, features_dict


